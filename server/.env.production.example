NODE_ENV=production
PORT=8787
APP_URL=https://cashback.example.vn
API_PUBLIC_URL=https://cashback.example.vn
DATABASE_PATH=/app/storage/hoantienvip.sqlite
WEB_DIST_PATH=/app/dist
SEED_DEMO_DATA=false
SESSION_COOKIE=hoantienvip_session
SESSION_TTL_HOURS=720
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://cashback.example.vn/api/v1/auth/google/callback
IP_HASH_PEPPER=replace-with-a-random-32-plus-character-secret
DATA_ENCRYPTION_KEY=replace-with-a-random-32-plus-character-secret
SHOPEE_AFFILIATE_MODE=graphql
SHOPEE_AFFILIATE_ENDPOINT=https://open-api.affiliate.shopee.vn/graphql
SHOPEE_AFFILIATE_ID=
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
TIKTOK_ADAPTER_MODE=mock
RIOHUB_BASE_URL=https://riohub.vn/api/v1
RIOHUB_API_KEY=

NODE_ENV=development
PORT=8787
APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8787
DATABASE_PATH=./storage/hoantienvip.sqlite
WEB_DIST_PATH=../dist
SEED_DEMO_DATA=true
SESSION_COOKIE=hoantienvip_session
SESSION_TTL_HOURS=720
DEV_OTP=123456
IP_HASH_PEPPER=replace-with-at-least-32-random-characters
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-key-before-production

# Shopee Affiliate Open API. Never expose these values to Vite/browser variables.
SHOPEE_AFFILIATE_MODE=disabled
SHOPEE_AFFILIATE_ENDPOINT=https://open-api.affiliate.shopee.vn/graphql
SHOPEE_AFFILIATE_ID=
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
SHOPEE_REQUEST_TIMEOUT_MS=10000

# TikTok/RioHub is intentionally mock-only until credentials and final contract are approved.
TIKTOK_ADAPTER_MODE=mock
RIOHUB_BASE_URL=https://riohub.vn/api/v1
RIOHUB_API_KEY=
